{
  "name": "LMIP_Warehouse_Build",
  "email_notifications": {
    "on_failure": ["aaryan.shrivastav1403@gmail.com"],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 18000,
  "trigger": {
    "pause_status": "UNPAUSED",
    "file_arrival": {
      "url": "dbfs:/databricks/workflows/triggers/semantic_processing_complete",
      "min_time_between_triggers_seconds": 3600
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Dim_Date",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_date",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Source",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_source",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Sector",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_sector",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 900,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Skill",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_skill",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Role",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_role",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 900,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Location",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_location",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Company",
      "depends_on": [{"task_key": "Dim_Sector"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_company",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Company_Alias",
      "depends_on": [{"task_key": "Dim_Company"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_company_alias",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dim_Job_SCD2",
      "depends_on": [
        {"task_key": "Dim_Company"},
        {"task_key": "Dim_Location"},
        {"task_key": "Dim_Role"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_job_scd2",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Bridge_Job_Skill",
      "depends_on": [
        {"task_key": "Dim_Job_SCD2"},
        {"task_key": "Dim_Skill"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_bridge_job_skill",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Fact_Job_Postings",
      "depends_on": [
        {"task_key": "Dim_Date"},
        {"task_key": "Dim_Job_SCD2"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_fact_job_postings",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Fact_Job_Lifecycle",
      "depends_on": [
        {"task_key": "Dim_Date"},
        {"task_key": "Dim_Job_SCD2"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_fact_job_lifecycle",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Fact_Salary",
      "depends_on": [
        {"task_key": "Dim_Date"},
        {"task_key": "Dim_Job_SCD2"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_fact_salary",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Fact_Pipeline_Runs",
      "depends_on": [{"task_key": "Dim_Date"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_fact_pipeline_runs",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Log_Pipeline_Audit",
      "depends_on": [
        {"task_key": "Bridge_Job_Skill"},
        {"task_key": "Fact_Job_Postings"},
        {"task_key": "Fact_Job_Lifecycle"},
        {"task_key": "Fact_Salary"},
        {"task_key": "Fact_Pipeline_Runs"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "base_parameters": {
          "pipeline_name": "warehouse_build",
          "job_id": "{{job.id}}",
          "run_id": "{{run.id}}",
          "status": "success",
          "start_time": "{{run.start_time}}",
          "catalog": "workspace",
          "schema": "audit"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 300,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}