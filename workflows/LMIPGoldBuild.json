{
  "name": "LMIP_Gold_Build",
  "email_notifications": {
    "on_failure": [
      "aaryan.shrivastav1403@gmail.com"
    ],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 14400,
  "trigger": {
    "pause_status": "UNPAUSED",
    "file_arrival": {
      "url": "dbfs:/databricks/workflows/triggers/warehouse_build_complete",
      "min_time_between_triggers_seconds": 3600
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Gold_Salary_Trends",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_salary_trends",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Skill_Demand",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_skill_demand",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Hiring_Trends",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_hiring_trends",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Company_Hiring",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_company_hiring",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Location_Trends",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_location_trends",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Sector_Overview",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_sector_overview",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Pipeline_Health",
      "depends_on": [
        {
          "task_key": "Gold_Salary_Trends"
        },
        {
          "task_key": "Gold_Skill_Demand"
        },
        {
          "task_key": "Gold_Hiring_Trends"
        }
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_pipeline_health",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Hiring_Activity",
      "depends_on": [
        {
          "task_key": "Gold_Sector_Overview"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_hiring_activity",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Skill_Demand_By_Sector",
      "depends_on": [
        {
          "task_key": "Gold_Skill_Demand"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_skill_demand_by_sector",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Gold_Company_Activity",
      "depends_on": [
        {
          "task_key": "Gold_Company_Hiring"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/gold/gold_company_activity",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Log_Pipeline_Execution",
      "depends_on": [
        {
          "task_key": "Gold_Pipeline_Health"
        },
        {
          "task_key": "Gold_Hiring_Activity"
        },
        {
          "task_key": "Gold_Skill_Demand_By_Sector"
        },
        {
          "task_key": "Gold_Company_Activity"
        },
        {
          "task_key": "Gold_Location_Trends"
        }
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "source": "WORKSPACE",
        "base_parameters": {
          "pipeline_name": "LMIP_Gold_Build",
          "run_id": "{{run_id}}",
          "status": "{{tasks.Gold_Pipeline_Health.state}}",
          "start_time": "{{start_time}}",
          "rows_read": "0",
          "rows_written": "0",
          "catalog": "workspace",
          "schema": "audit"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Notify_On_Failure",
      "depends_on": [
        {
          "task_key": "Gold_Pipeline_Health"
        },
        {
          "task_key": "Gold_Hiring_Activity"
        },
        {
          "task_key": "Gold_Skill_Demand_By_Sector"
        },
        {
          "task_key": "Gold_Company_Activity"
        },
        {
          "task_key": "Gold_Location_Trends"
        }
      ],
      "run_if": "AT_LEAST_ONE_FAILED",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/audit_notification_dispatch",
        "source": "WORKSPACE",
        "base_parameters": {
          "notification_type": "critical_alert",
          "alert_severity": "HIGH",
          "alert_title": "LMIP Gold Build Pipeline Failed",
          "alert_message": "Pipeline LMIP_Gold_Build (Run ID: {{run_id}}) encountered failures. Check audit logs and investigate immediately.",
          "alert_context": "{\"workflow_name\": \"LMIP_Gold_Build\", \"run_id\": \"{{run_id}}\", \"run_page_url\": \"{{run_page_url}}\"}",
          "recipient_list": "aaryan.shrivastav1403@gmail.com,data-ops-team@company.com",
          "channel": "email"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
