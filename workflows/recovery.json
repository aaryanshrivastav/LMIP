{
  "name": "LMIP_Recovery",
  "email_notifications": {
    "on_start": ["aaryan.shrivastav1403@gmail.com"],
    "on_success": ["aaryan.shrivastav1403@gmail.com"],
    "on_failure": ["aaryan.shrivastav1403@gmail.com"],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 21600,
  "trigger": {
    "pause_status": "PAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Recovery_Bronze_Replay_Backfill",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_replay_backfill",
        "base_parameters": {
          "start_date": "{{job.parameters.start_date}}",
          "end_date": "{{job.parameters.end_date}}",
          "source_filter": "{{job.parameters.source_filter}}"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 7200,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_Quarantine_Manage",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/quarantine/quarantine_manage",
        "base_parameters": {
          "action": "{{job.parameters.quarantine_action}}",
          "entity_type": "{{job.parameters.entity_type}}",
          "batch_size": "1000"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_Silver_Reprocess",
      "depends_on": [{"task_key": "Recovery_Bronze_Replay_Backfill"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_standardize_jobs",
        "base_parameters": {
          "mode": "full",
          "batch_id": "{{job.parameters.batch_id}}"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 7200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_CDC_Reprocess",
      "depends_on": [{"task_key": "Recovery_Silver_Reprocess"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_detect_cdc",
        "base_parameters": {
          "enable_deletes": "true",
          "batch_id": "{{job.parameters.batch_id}}"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 7200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_Semantic_Reprocess",
      "depends_on": [{"task_key": "Recovery_CDC_Reprocess"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_role_map",
        "base_parameters": {
          "reprocess_mode": "true",
          "confidence_threshold": "0.6"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 7200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_Warehouse_Rebuild",
      "depends_on": [{"task_key": "Recovery_Semantic_Reprocess"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/warehouse/wh_dim_job_scd2",
        "base_parameters": {
          "full_refresh": "true"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 7200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Recovery_Validation_Report",
      "depends_on": [
        {"task_key": "Recovery_Bronze_Replay_Backfill"},
        {"task_key": "Recovery_Quarantine_Manage"},
        {"task_key": "Recovery_Warehouse_Rebuild"}
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/audit_generate_report",
        "base_parameters": {
          "report_type": "recovery",
          "include_metrics": "true"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "email_notifications": {
        "on_success": ["aaryan.shrivastav1403@gmail.com"]
      },
      "environment_key": "Default"
    }
  ],
  "parameters": [
    {
      "name": "start_date",
      "default": "2026-06-01"
    },
    {
      "name": "end_date",
      "default": "2026-06-07"
    },
    {
      "name": "source_filter",
      "default": "remotive,arbeitnow"
    },
    {
      "name": "batch_id",
      "default": "latest"
    },
    {
      "name": "quarantine_action",
      "default": "review"
    },
    {
      "name": "entity_type",
      "default": "all"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}