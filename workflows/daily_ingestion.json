{
  "name": "LMIP_Daily_Ingestion",
  "email_notifications": {
    "on_failure": ["aaryan.shrivastav1403@gmail.com"],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 7200,
  "trigger": {
    "pause_status": "UNPAUSED",
    "periodic": {
      "interval": 1,
      "unit": "DAYS"
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Ingest_Remotive",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/ingestion/ingest_remotive",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": true,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Ingest_Arbeitnow",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/ingestion/ingest_arbeitnow",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": true,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Bronze_Write_API_Log",
      "depends_on": [
        {"task_key": "Ingest_Remotive"},
        {"task_key": "Ingest_Arbeitnow"}
      ],
      "run_if": "AT_LEAST_ONE_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_write_api_response_log",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Bronze_Write_Job_Snapshot",
      "depends_on": [{"task_key": "Bronze_Write_API_Log"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_write_job_snapshot",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 900,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Bronze_Dedupe_Raw_Payload",
      "depends_on": [{"task_key": "Bronze_Write_Job_Snapshot"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_dedupe_raw_payload",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1200,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Bronze_Finalize_Batch",
      "depends_on": [{"task_key": "Bronze_Dedupe_Raw_Payload"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_finalize_batch",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}