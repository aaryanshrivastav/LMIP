{
  "name": "LMIP_Semantic_Processing",
  "email_notifications": {
    "on_failure": ["aaryan.shrivastav1403@gmail.com"],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 14400,
  "trigger": {
    "pause_status": "UNPAUSED",
    "file_arrival": {
      "url": "dbfs:/databricks/workflows/triggers/silver_processing_complete",
      "min_time_between_triggers_seconds": 7200
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Semantic_Role_Map",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_role_map",
        "base_parameters": {
          "confidence_threshold": "0.7",
          "enable_llm_fallback": "false"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Company_Canonicalize",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_company_canonicalize",
        "base_parameters": {
          "fuzzy_threshold": "0.85"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Sector_Normalize",
      "depends_on": [
        {"task_key": "Semantic_Role_Map"},
        {"task_key": "Semantic_Company_Canonicalize"}
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_sector_normalize",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Skill_Catalog_Sync",
      "depends_on": [{"task_key": "Semantic_Sector_Normalize"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_skill_catalog_sync",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Skill_Graph_Build",
      "depends_on": [{"task_key": "Semantic_Skill_Catalog_Sync"}],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_skill_graph_build",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Review_Resolver",
      "depends_on": [{"task_key": "Semantic_Skill_Graph_Build"}],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_review_resolver",
        "base_parameters": {
          "auto_approve_high_confidence": "true",
          "confidence_threshold": "0.90"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
