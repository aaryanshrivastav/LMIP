{
  "name": "LMIP_Publishing",
  "email_notifications": {
    "on_success": [
      "aaryan.shrivastav1403@gmail.com"
    ],
    "on_failure": [
      "aaryan.shrivastav1403@gmail.com"
    ],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 10800,
  "trigger": {
    "pause_status": "UNPAUSED",
    "file_arrival": {
      "url": "dbfs:/databricks/workflows/triggers/gold_build_complete",
      "min_time_between_triggers_seconds": 7200
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Publish_CSV_Snapshot_Export",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/publish/publish_csv_snapshot_export",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": true,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Publish_Manifest_Write",
      "depends_on": [
        {
          "task_key": "Publish_CSV_Snapshot_Export"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/publish/publish_manifest_write",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Publish_Load_Order_Check",
      "depends_on": [
        {
          "task_key": "Publish_Manifest_Write"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/publish/publish_load_order_check",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Publish_Supabase_Upsert",
      "depends_on": [
        {
          "task_key": "Publish_Load_Order_Check"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/publish/publish_supabase_upsert",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 3,
      "min_retry_interval_millis": 180000,
      "retry_on_timeout": true,
      "email_notifications": {
        "on_failure": [
          "aaryan.shrivastav1403@gmail.com"
        ]
      },
      "environment_key": "Default"
    },
    {
      "task_key": "Log_Pipeline_Execution",
      "depends_on": [
        {
          "task_key": "Publish_Supabase_Upsert"
        }
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "source": "WORKSPACE",
        "base_parameters": {
          "pipeline_name": "LMIP_Publishing",
          "run_id": "{{run_id}}",
          "status": "{{tasks.Publish_Supabase_Upsert.state}}",
          "start_time": "{{start_time}}",
          "rows_read": "0",
          "rows_written": "0",
          "catalog": "workspace",
          "schema": "audit"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Notify_On_Failure",
      "depends_on": [
        {
          "task_key": "Publish_Supabase_Upsert"
        }
      ],
      "run_if": "AT_LEAST_ONE_FAILED",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/audit_notification_dispatch",
        "source": "WORKSPACE",
        "base_parameters": {
          "notification_type": "critical_alert",
          "alert_severity": "HIGH",
          "alert_title": "LMIP_Publishing Pipeline Failed",
          "alert_message": "Pipeline LMIP_Publishing (Run ID: {{run_id}}) encountered failures. Check audit logs and investigate immediately.",
          "alert_context": "{\"workflow_name\": \"LMIP_Publishing\", \"run_id\": \"{{run_id}}\", \"run_page_url\": \"{{run_page_url}}\"}",
          "recipient_list": "aaryan.shrivastav1403@gmail.com,data-ops-team@company.com",
          "channel": "email"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}