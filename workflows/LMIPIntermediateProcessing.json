{
  "name": "LMIP_Intermediate_Processing",
  "email_notifications": {
    "on_failure": [
      "aaryan.shrivastav1403@gmail.com"
    ],
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 14400,
  "trigger": {
    "pause_status": "UNPAUSED",
    "file_arrival": {
      "url": "dbfs:/databricks/workflows/triggers/silver_processing_complete",
      "min_time_between_triggers_seconds": 7200
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Semantic_Role_Map",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/inter_role_map",
        "base_parameters": {
          "confidence_threshold": "0.7",
          "enable_llm_fallback": "false"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Company_Canonicalize",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/inter_company_canonicalize",
        "base_parameters": {
          "fuzzy_threshold": "0.85"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Sector_Normalize",
      "depends_on": [
        {
          "task_key": "Semantic_Role_Map"
        },
        {
          "task_key": "Semantic_Company_Canonicalize"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/inter_sector_normalize",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Skill_Catalog_Sync",
      "depends_on": [
        {
          "task_key": "Semantic_Sector_Normalize"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/inter_skill_catalog_sync",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 2400,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Semantic_Skill_Graph_Build",
      "depends_on": [
        {
          "task_key": "Semantic_Skill_Catalog_Sync"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/inter_skill_graph_build",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Log_Pipeline_Execution",
      "depends_on": [
        {
          "task_key": "Semantic_Skill_Graph_Build"
        }
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "base_parameters": {
          "pipeline_name": "LMIP_Intermediate_Processing",
          "run_id": "{{run_id}}",
          "status": "{{tasks.Semantic_Skill_Graph_Build.state}}",
          "start_time": "{{start_time}}",
          "rows_read": "0",
          "rows_written": "0",
          "catalog": "workspace",
          "schema": "audit"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Notify_On_Failure",
      "depends_on": [
        {
          "task_key": "Semantic_Skill_Graph_Build"
        }
      ],
      "run_if": "AT_LEAST_ONE_FAILED",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/audit_notification_dispatch",
        "source": "WORKSPACE",
        "base_parameters": {
          "notification_type": "critical_alert",
          "alert_severity": "HIGH",
          "alert_title": "LMIP Intermediate Processing Pipeline Failed",
          "alert_message": "Pipeline LMIP_Intermediate_Processing (Run ID: {{run_id}}) encountered failures. Check audit logs and investigate immediately.",
          "alert_context": "{\"workflow_name\": \"LMIP_Intermediate_Processing\", \"run_id\": \"{{run_id}}\", \"run_page_url\": \"{{run_page_url}}\"}",
          "recipient_list": "aaryan.shrivastav1403@gmail.com,data-ops-team@company.com",
          "channel": "email"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
