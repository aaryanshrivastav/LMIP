        "base_parameters": {
          "notification_type": "critical_alert",
          "alert_severity": "HIGH",
          "alert_title": "LMIP_Warehouse_Build Pipeline Failed",
          "alert_message": "Pipeline LMIP_Warehouse_Build (Run ID: {{run_id}}) encountered failures. Check audit logs and investigate immediately.",
          "alert_context": "{\"workflow_name\": \"LMIP_Warehouse_Build\", \"run_id\": \"{{run_id}}\", \"run_page_url\": \"{{run_page_url}}\"}",
          "recipient_list": "aaryan.shrivastav1403@gmail.com,data-ops-team@company.com",
          "channel": "email"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "email_notifications": {},
      "environment_key": "Default"
    }
