      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "base_parameters": {
          "pipeline_name": "warehouse_build",
          "job_id": "{{job.id}}",
          "run_id": "{{run.id}}",
          "status": "success",
          "start_time": "{{run.start_time}}",
          "catalog": "workspace",
          "schema": "audit",
          "rows_read": "0",
          "rows_written": "0"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 300,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Notify_On_Failure",
      "depends_on": [
        {
          "task_key": "Dim_Source"
        },
        {
          "task_key": "Dim_Company_Alias"
        }
      ],
      "run_if": "AT_LEAST_ONE_FAILED",
