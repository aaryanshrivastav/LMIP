{
  "name": "LMIPSilverProcessing",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Standardize_Jobs",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_standardize_jobs",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Detection_CDC",
      "depends_on": [
        {
          "task_key": "Standardize_Jobs"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_detect_cdc",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Apply_Soft_Delete",
      "depends_on": [
        {
          "task_key": "Detection_CDC"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_apply_soft_delete_restore",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "DQ_Validate",
      "depends_on": [
        {
          "task_key": "Apply_Soft_Delete"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_dq_validate",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Sector_Assign",
      "depends_on": [
        {
          "task_key": "DQ_Validate"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_sector_assign",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Skill_Extract",
      "depends_on": [
        {
          "task_key": "DQ_Validate"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_skill_extract",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Identity_Map",
      "depends_on": [
        {
          "task_key": "Sector_Assign"
        },
        {
          "task_key": "Skill_Extract"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/silver/silver_job_identity_map",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Logger",
      "depends_on": [
        {
          "task_key": "Identity_Map"
        }
      ],
      "run_if": "ALL_DONE",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/log_pipeline_run",
        "source": "WORKSPACE",
        "base_parameters": {
          "rows_read": "0",
          "rows_written": "0",
          "start_time": "{{start_time}}"
        }
      },
      "timeout_seconds": 0,
      "email_notifications": {}
    },
    {
      "task_key": "Notify_On_Failure",
      "depends_on": [
        {
          "task_key": "Logger"
        }
      ],
      "run_if": "AT_LEAST_ONE_FAILED",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/audit/audit_notification_dispatch",
        "source": "WORKSPACE",
        "base_parameters": {
          "notification_type": "critical_alert",
          "alert_severity": "HIGH",
          "alert_title": "LMIPSilverProcessing_TEST [TEST] Pipeline Failed",
          "alert_message": "TEST Pipeline LMIPSilverProcessing_TEST (Run ID: {{run_id}}) encountered failures. Check audit logs.",
          "alert_context": "{\"workflow_name\": \"LMIPSilverProcessing_TEST\", \"run_id\": \"{{run_id}}\", \"run_page_url\": \"{{run_page_url}}\", \"environment\": \"TEST\"}",
          "recipient_list": "aaryan.shrivastav1403@gmail.com",
          "channel": "email"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}