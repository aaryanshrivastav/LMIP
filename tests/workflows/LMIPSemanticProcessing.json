        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Role_Map",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/semantic/semantic_role_map",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
