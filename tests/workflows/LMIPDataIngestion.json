{
  "name": "LMIPDataIngestion",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "timeout_seconds": 0,
  "trigger": {
    "pause_status": "UNPAUSED",
    "periodic": {
      "interval": 1,
      "unit": "HOURS"
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Arbeit_Ingestor",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/ingestion/ingest_arbeitnow",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Remotive_Ingestor",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/ingestion/ingest_remotive",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "API_Log",
      "depends_on": [
        {
          "task_key": "Arbeit_Ingestor"
        },
        {
          "task_key": "Remotive_Ingestor"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_write_api_response_log",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Job_Snapshot",
      "depends_on": [
        {
          "task_key": "API_Log"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_write_job_snapshot",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze",
          "job_id": "{{job.id}}",
          "job_name": "{{job.name}}",
          "batch_id": "{{run.start_time}}",
          "run_id": "{{run.id}}",
          "status": "running",
          "config_json": "{}"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Dedupe_Check",
      "depends_on": [
        {
          "task_key": "Job_Snapshot"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_dedupe_raw_payload",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    },
    {
      "task_key": "Finalise_Batch",
      "depends_on": [
        {
          "task_key": "Dedupe_Check"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/aaryan.shrivastav1403@gmail.com/LMIP/notebooks/bronze/bronze_finalize_batch",
        "base_parameters": {
          "catalog": "workspace",
          "schema": "bronze"
        },
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "environment_key": "Default"
    }
  ],
  "format": "MULTI_TASK",
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "Default",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}