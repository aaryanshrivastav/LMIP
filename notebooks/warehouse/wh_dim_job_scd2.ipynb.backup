     "nuid": "913cd998-dc43-41d9-9963-308a2bd09cdb",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validation - Summary Statistics"
    }
   },
   "outputs": [],
   "source": [
    "%sql\n",
    "-- Validate job dimension\n",
    "SELECT \n",
    "  COUNT(*) as total_job_versions,\n",
    "  COUNT(DISTINCT enterprise_job_id) as unique_jobs,\n",
    "  SUM(CASE WHEN is_current THEN 1 ELSE 0 END) as current_versions,\n",
    "  COUNT(*) - SUM(CASE WHEN is_current THEN 1 ELSE 0 END) as historical_versions,\n",
    "  AVG(CASE WHEN effective_to IS NULL THEN 0 ELSE DATEDIFF(effective_to, effective_from) END) as avg_version_duration_days,\n",
    "  SUM(CASE WHEN company_sk = -1 THEN 1 ELSE 0 END) as missing_company_fk,\n",
    "  SUM(CASE WHEN location_sk = -1 THEN 1 ELSE 0 END) as missing_location_fk\n",
    "FROM workspace.warehouse.dim_job;"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "implicitDf": true,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "74e20339-9f13-4e5d-92d3-e30f0cb77427",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validation - Sample Job History"
    }
   },
   "outputs": [],
   "source": [
    "%sql\n",
    "-- Sample job history (jobs with multiple versions)\n",
    "SELECT \n",
    "  job_sk,\n",
    "  enterprise_job_id,\n",
    "  title_normalized,\n",
    "  company_sk,\n",
    "  location_sk,\n",
    "  remote_type,\n",
    "  effective_from,\n",
    "  effective_to,\n",
    "  is_current\n",
    "FROM workspace.warehouse.dim_job\n",
    "WHERE enterprise_job_id IN (\n",
    "  SELECT enterprise_job_id \n",
    "  FROM workspace.warehouse.dim_job \n",
    "  GROUP BY enterprise_job_id \n",
    "  HAVING COUNT(*) > 1 \n",
    "  LIMIT 10\n",
    ")\n",
    "ORDER BY enterprise_job_id, effective_from\n",
    "LIMIT 50;"
   ]
  }
 ],
