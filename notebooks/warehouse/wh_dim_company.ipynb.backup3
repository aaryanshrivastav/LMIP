    "%sql\n",
    "-- Show refresh history\n",
    "SELECT \n",
    "  run_id,\n",
    "  companies_extracted,\n",
    "  companies_inserted,\n",
    "  companies_updated,\n",
    "  force_full_refresh,\n",
    "  processed_at,\n",
    "  status\n",
    "FROM workspace.metadata.dim_company_refresh_log\n",
    "ORDER BY processed_at DESC\n",
    "LIMIT 10;"
   ]
  }
 ],
