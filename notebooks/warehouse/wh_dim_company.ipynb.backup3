   },
   "outputs": [],
   "source": [
    "%sql\n",
    "-- Sample companies with sector and match info\n",
    "SELECT \n",
    "  company_sk,\n",
    "  company_name,\n",
    "  company_name_canonical,\n",
    "  sector_name,\n",
    "  company_match_method,\n",
    "  match_confidence,\n",
    "  alias_count,\n",
    "  is_active,\n",
    "  updated_at\n",
    "FROM workspace.warehouse.dim_company\n",
    "ORDER BY match_confidence DESC, company_name\n",
    "LIMIT 25;"
   ]
  },
  {
