     "nuid": "1c521774-ec28-4b83-9cf9-a71c59ce3e55",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "LMIP Environment Validation"
    }
   },
   "source": [
    "# LMIP Environment Validation\n",
    "\n",
    "**Purpose**: Validate runtime environment and dependencies for LMIP deployment\n",
    "\n",
    "**Validation Checks**:\n",
    "* Python version and required packages\n",
    "* Spark configuration and cluster resources\n",
    "* Catalog and schema existence\n",
    "* Table structure validation\n",
    "* Network connectivity (API endpoints)\n",
    "* Permissions and access control\n",
    "\n",
    "---\n",
    "\n",
    "## Usage\n",
    "\n",
    "**First-time initialization**:\n",
    "```python\n",
    "result = dbutils.notebook.run(\"/LMIP/notebooks/init/init_validate_env\", timeout_seconds=300)\n",
    "if result != \"SUCCESS\":\n",
    "    raise Exception(\"Environment validation failed\")\n",
    "```\n",
    "\n",
    "**Returns**: SUCCESS, WARNINGS, or FAILED"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "159f305e-512a-44e9-9efa-7f24a9cb2284",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Configuration and Imports"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "from datetime import datetime, timezone\n",
    "import sys\n",
    "import requests\n",
    "from pyspark.sql import functions as F\n",
    "\n",
    "# Configuration\n",
    "CATALOG = \"workspace\"\n",
    "REQUIRED_SCHEMAS = [\"metadata\", \"bronze\", \"silver\", \"semantic\", \"warehouse\", \"gold\", \"audit\", \"publish\", \"quarantine\"]\n",
    "REQUIRED_PYTHON_VERSION = \"3.10\"\n",
    "REQUIRED_PACKAGES = [\"requests\", \"pyspark\"]\n",
    "API_ENDPOINTS_TO_TEST = [\n",
    "    \"https://remotive.com/api/remote-jobs\",\n",
    "    \"https://www.arbeitnow.com/api/job-board-api\"\n",
    "]\n",
    "\n",
    "# Validation results tracking\n",
    "validation_results = []\n",
    "\n",
    "def log_check(check_name, status, message):\n",
    "    \"\"\"Log validation check result\"\"\"\n",
    "    validation_results.append({\n",
    "        \"check\": check_name,\n",
    "        \"status\": status,\n",
    "        \"message\": message,\n",
    "        \"timestamp\": datetime.now(timezone.utc)\n",
    "    })\n",
    "    symbol = \"✓\" if status == \"PASS\" else (\"⚠\" if status == \"WARN\" else \"✗\")\n",
    "    print(f\"{symbol} {check_name}: {message}\")\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"LMIP ENVIRONMENT VALIDATION\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Started: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')}\")\n",
    "print(f\"Catalog: {CATALOG}\")\n",
    "print()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "9501c81c-9134-4655-9238-732de121136d",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Python Environment"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[1] Python Environment\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Check Python version\n",
    "python_version = f\"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}\"\n",
    "if sys.version_info >= (3, 10):\n",
    "    log_check(\"Python Version\", \"PASS\", f\"Python {python_version}\")\n",
    "else:\n",
    "    log_check(\"Python Version\", \"WARN\", f\"Python {python_version} (recommended >= 3.10)\")\n",
    "\n",
    "# Check required packages\n",
    "for package in REQUIRED_PACKAGES:\n",
    "    try:\n",
    "        __import__(package)\n",
    "        log_check(f\"Package: {package}\", \"PASS\", \"Installed\")\n",
    "    except ImportError:\n",
    "        log_check(f\"Package: {package}\", \"FAIL\", \"Not installed\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "4a5158d7-9dba-49c2-bbd2-02c36551aef8",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Spark Environment"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[2] Spark Environment\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Check Spark version\n",
    "spark_version = spark.version\n",
    "log_check(\"Spark Version\", \"PASS\", f\"Spark {spark_version}\")\n",
    "\n",
    "# Check Spark configuration\n",
    "spark_conf = spark.sparkContext.getConf().getAll()\n",
    "key_configs = {\n",
    "    \"spark.sql.adaptive.enabled\": \"Adaptive Query Execution\",\n",
    "    \"spark.databricks.delta.preview.enabled\": \"Delta Lake Preview\"\n",
    "}\n",
    "\n",
    "for config_key, config_name in key_configs.items():\n",
    "    config_value = dict(spark_conf).get(config_key, \"Not Set\")\n",
    "    if config_value:\n",
    "        log_check(config_name, \"PASS\", f\"{config_value}\")\n",
    "    else:\n",
    "        log_check(config_name, \"WARN\", \"Not configured\")\n",
    "\n",
    "# Check cluster resources\n",
    "try:\n",
    "    # Simple test query to verify cluster is responsive\n",
    "    spark.sql(\"SELECT 1 as test\").collect()\n",
    "    log_check(\"Cluster Responsiveness\", \"PASS\", \"Cluster is responsive\")\n",
    "except Exception as e:\n",
    "    log_check(\"Cluster Responsiveness\", \"FAIL\", f\"Error: {str(e)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "23332a3d-1d57-4895-86ee-139912200595",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Catalog and Schemas"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[3] Catalog and Schemas\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Check catalog exists\n",
    "try:\n",
    "    catalogs_df = spark.sql(\"SHOW CATALOGS\")\n",
    "    catalogs = [row.catalog for row in catalogs_df.collect()]\n",
    "    if CATALOG in catalogs:\n",
    "        log_check(f\"Catalog: {CATALOG}\", \"PASS\", \"Exists\")\n",
    "    else:\n",
    "        log_check(f\"Catalog: {CATALOG}\", \"FAIL\", \"Does not exist\")\n",
    "except Exception as e:\n",
    "    log_check(f\"Catalog: {CATALOG}\", \"FAIL\", f\"Error: {str(e)}\")\n",
    "\n",
    "# Check required schemas\n",
    "try:\n",
    "    schemas_df = spark.sql(f\"SHOW SCHEMAS IN {CATALOG}\")\n",
    "    existing_schemas = [row.databaseName for row in schemas_df.collect()]\n",
    "    \n",
    "    for schema in REQUIRED_SCHEMAS:\n",
    "        if schema in existing_schemas:\n",
    "            log_check(f\"Schema: {schema}\", \"PASS\", \"Exists\")\n",
    "        else:\n",
    "            log_check(f\"Schema: {schema}\", \"FAIL\", \"Does not exist\")\n",
    "except Exception as e:\n",
    "    log_check(\"Schema Validation\", \"FAIL\", f\"Error: {str(e)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "ff61a0c5-851d-4660-8008-a4fb00f61d1d",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Key Tables"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[4] Key Tables\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Define key tables to validate\n",
    "key_tables = [\n",
    "    (\"metadata\", \"source_config\"),\n",
    "    (\"bronze\", \"bronze_job_snapshot\"),\n",
    "    (\"bronze\", \"bronze_api_response_log\"),\n",
    "    (\"silver\", \"silver_jobs_current\"),\n",
    "    (\"audit\", \"audit_pipeline_runs\")\n",
    "]\n",
    "\n",
    "for schema, table in key_tables:\n",
    "    full_table_name = f\"{CATALOG}.{schema}.{table}\"\n",
    "    try:\n",
    "        # Try to query table\n",
    "        spark.sql(f\"SELECT COUNT(*) as cnt FROM {full_table_name}\").collect()\n",
    "        log_check(f\"Table: {schema}.{table}\", \"PASS\", \"Accessible\")\n",
    "    except Exception as e:\n",
    "        error_msg = str(e)\n",
    "        if \"TABLE_OR_VIEW_NOT_FOUND\" in error_msg or \"does not exist\" in error_msg.lower():\n",
    "            log_check(f\"Table: {schema}.{table}\", \"WARN\", \"Table not created yet\")\n",
    "        else:\n",
    "            log_check(f\"Table: {schema}.{table}\", \"FAIL\", f\"Error: {error_msg[:100]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "b3f01e08-daa7-4187-8eb9-5647f378e771",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Network Connectivity"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[5] Network Connectivity\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Test API endpoint connectivity\n",
    "for endpoint in API_ENDPOINTS_TO_TEST:\n",
    "    try:\n",
    "        response = requests.get(endpoint, timeout=10)\n",
    "        if response.status_code == 200:\n",
    "            log_check(f\"API: {endpoint}\", \"PASS\", f\"Reachable (HTTP {response.status_code})\")\n",
    "        else:\n",
    "            log_check(f\"API: {endpoint}\", \"WARN\", f\"HTTP {response.status_code}\")\n",
    "    except requests.exceptions.Timeout:\n",
    "        log_check(f\"API: {endpoint}\", \"WARN\", \"Timeout\")\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        log_check(f\"API: {endpoint}\", \"WARN\", f\"Connection error: {str(e)[:50]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "8ad3db49-ed34-4cfa-9ef9-a23802d0585d",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Validate Permissions"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n[6] Permissions\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "# Test CREATE TABLE permission\n",
    "try:\n",
    "    test_table = f\"{CATALOG}.metadata.test_permissions_validation\"\n",
    "    spark.sql(f\"CREATE TABLE IF NOT EXISTS {test_table} (id INT) USING DELTA\")\n",
    "    spark.sql(f\"DROP TABLE IF EXISTS {test_table}\")\n",
    "    log_check(\"CREATE TABLE Permission\", \"PASS\", \"Can create tables\")\n",
    "except Exception as e:\n",
    "    log_check(\"CREATE TABLE Permission\", \"FAIL\", f\"Error: {str(e)[:100]}\")\n",
    "\n",
    "# Test INSERT permission\n",
    "try:\n",
    "    # Try to insert into audit table (most permissive)\n",
    "    test_query = f\"\"\"\n",
    "    SELECT 'test' as audit_run_sk, \n",
    "           'test' as run_id, \n",
    "           'validation' as pipeline_name, \n",
    "           'TEST' as environment,\n",
    "           current_timestamp() as start_time\n",
    "    \"\"\"\n",
    "    test_df = spark.sql(test_query)\n",
    "    # Don't actually insert, just validate we can create the DF\n",
    "    log_check(\"INSERT Permission\", \"PASS\", \"Can prepare insert statements\")\n",
    "except Exception as e:\n",
    "    log_check(\"INSERT Permission\", \"WARN\", f\"Error: {str(e)[:100]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "c3ef32b2-2b2e-41af-a57e-d4489dc30d3b",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Summary and Exit"
    }
   },
   "outputs": [],
   "source": [
    "# Databricks notebook source\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"VALIDATION SUMMARY\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Count results\n",
    "passed = sum(1 for r in validation_results if r[\"status\"] == \"PASS\")\n",
    "warnings = sum(1 for r in validation_results if r[\"status\"] == \"WARN\")\n",
    "failed = sum(1 for r in validation_results if r[\"status\"] == \"FAIL\")\n",
    "total = len(validation_results)\n",
    "\n",
    "print(f\"\\nTotal Checks: {total}\")\n",
    "print(f\"✓ Passed: {passed}\")\n",
    "print(f\"⚠ Warnings: {warnings}\")\n",
    "print(f\"✗ Failed: {failed}\")\n",
    "\n",
    "# Determine overall status\n",
    "if failed > 0:\n",
    "    overall_status = \"FAILED\"\n",
    "    print(\"\\n✗ VALIDATION FAILED\")\n",
    "    print(\"\\nFailed checks:\")\n",
    "    for result in validation_results:\n",
    "        if result[\"status\"] == \"FAIL\":\n",
    "            print(f\"  - {result['check']}: {result['message']}\")\n",
    "elif warnings > 0:\n",
    "    overall_status = \"WARNINGS\"\n",
    "    print(\"\\n⚠ VALIDATION COMPLETED WITH WARNINGS\")\n",
    "    print(\"\\nWarnings:\")\n",
    "    for result in validation_results:\n",
    "        if result[\"status\"] == \"WARN\":\n",
    "            print(f\"  - {result['check']}: {result['message']}\")\n",
    "else:\n",
    "    overall_status = \"SUCCESS\"\n",
    "    print(\"\\n✓ ALL VALIDATIONS PASSED\")\n",
    "\n",
    "print(f\"\\nCompleted: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')}\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Return status for orchestration\n",
    "dbutils.notebook.exit(overall_status)"
   ]
  }
 ],
