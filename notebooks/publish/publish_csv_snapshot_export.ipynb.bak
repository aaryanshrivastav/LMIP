     "nuid": "72193349-bd8a-42fe-8e36-c122c4adf3cd",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Publish CSV Snapshot Export"
    }
   },
   "source": [
    "# Publish: CSV Snapshot Export\n",
    "\n",
    "**Purpose**: Export Gold and Audit tables as deterministic CSV snapshot bundles for consumer-mode bootstrap and offline distribution.\n",
    "\n",
    "**Key Features**:\n",
    "- Deterministic exports (sorted by primary key)\n",
    "- Compression (gzip)\n",
    "- Checksum generation (MD5)\n",
    "- Metadata files with schema info\n",
    "- Versioned snapshots with timestamps\n",
    "- Compatibility markers\n",
    "\n",
    "**Output Structure**:\n",
    "```\n",
    "/Volumes/workspace/publish/snapshots/YYYY-MM-DD_HHmmss/\n",
    "  ├── data/\n",
    "  │   ├── dim_date.csv.gz\n",
    "  │   ├── dim_sector.csv.gz\n",
    "  │   ├── fact_job_postings.csv.gz\n",
    "  │   └── ...\n",
    "  ├── checksums.json\n",
    "  ├── metadata.json\n",
    "  └── snapshot_manifest.json\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "30209c8a-4384-409b-be54-af89711ae6b1",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Configuration"
    }
   },
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import hashlib\n",
    "import gzip\n",
    "from datetime import datetime\n",
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "from pyspark.sql import DataFrame\n",
    "from pyspark.sql.functions import col\n",
    "\n",
    "# Configuration\n",
    "CATALOG = \"workspace\"\n",
    "WAREHOUSE_SCHEMA = \"warehouse\"  # Dimensions and Facts\n",
    "GOLD_SCHEMA = \"gold\"  # Analytics marts\n",
    "AUDIT_SCHEMA = \"audit\"  # Audit tables\n",
    "VOLUME_PATH = \"/Volumes/workspace/publish/snapshots\"\n",
    "\n",
    "# Generate snapshot timestamp\n",
    "SNAPSHOT_TIMESTAMP = datetime.now().strftime(\"%Y-%m-%d_%H%M%S\")\n",
    "SNAPSHOT_DIR = f\"{VOLUME_PATH}/{SNAPSHOT_TIMESTAMP}\"\n",
    "DATA_DIR = f\"{SNAPSHOT_DIR}/data\"\n",
    "\n",
    "# Create directories\n",
    "dbutils.fs.mkdirs(DATA_DIR)\n",
    "\n",
    "print(f\"✓ Snapshot directory: {SNAPSHOT_DIR}\")\n",
    "print(f\"✓ Data directory: {DATA_DIR}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "b9c25890-9638-46aa-b1ee-ed0572de6dce",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Table Export Order"
    }
   },
   "outputs": [],
   "source": [
    "# Table export configuration\n",
    "# Format: (table_name, sort_columns, schema)\n",
    "EXPORT_CONFIG = [\n",
    "    # Warehouse Dimensions\n",
    "    (\"dim_source\", [\"source_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_sector\", [\"sector_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_role\", [\"role_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_location\", [\"location_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_company\", [\"company_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_skill\", [\"skill_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_job\", [\"job_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"dim_company_alias\", [\"company_sk\", \"alias_name\"], WAREHOUSE_SCHEMA),\n",
    "    \n",
    "    # Warehouse Facts\n",
    "    (\"fact_job_postings\", [\"fact_job_posting_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"fact_job_lifecycle\", [\"fact_job_lifecycle_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"fact_salary\", [\"fact_salary_sk\"], WAREHOUSE_SCHEMA),\n",
    "    (\"fact_pipeline_runs\", [\"fact_pipeline_run_sk\"], WAREHOUSE_SCHEMA),\n",
    "    \n",
    "    # Warehouse Bridges\n",
    "    (\"bridge_job_skill\", [\"job_sk\", \"skill_sk\"], WAREHOUSE_SCHEMA),\n",
    "    \n",
    "    # Gold Analytics Marts\n",
    "    (\"gold_hiring_trends\", [\"trend_date_sk\", \"sector_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_sector_overview\", [\"sector_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_location_trends\", [\"location_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_company_hiring\", [\"company_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_salary_trends\", [\"trend_date_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_skill_demand\", [\"skill_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_hospitality_companies\", [\"company_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_hospitality_hiring\", [\"trend_date_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_hospitality_skills\", [\"skill_sk\"], GOLD_SCHEMA),\n",
    "    (\"gold_pipeline_health\", [\"run_date\"], GOLD_SCHEMA),\n",
    "    \n",
    "    # Audit tables (corrected timestamp column names)\n",
    "    (\"audit_pipeline_runs\", [\"start_time\"], AUDIT_SCHEMA),\n",
    "    (\"audit_dq_results\", [\"evaluated_at\"], AUDIT_SCHEMA),\n",
    "    (\"audit_access_events\", [\"event_time\"], AUDIT_SCHEMA),\n",
    "]\n",
    "\n",
    "print(f\"✓ Export configuration loaded: {len(EXPORT_CONFIG)} tables\")\n",
    "print(f\"  Warehouse: {sum(1 for _, _, s in EXPORT_CONFIG if s == WAREHOUSE_SCHEMA)} tables\")\n",
    "print(f\"  Gold: {sum(1 for _, _, s in EXPORT_CONFIG if s == GOLD_SCHEMA)} tables\")\n",
    "print(f\"  Audit: {sum(1 for _, _, s in EXPORT_CONFIG if s == AUDIT_SCHEMA)} tables\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "cf7f5b33-0515-46ba-be22-43eb13ff08a0",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Export Functions"
    }
   },
   "outputs": [],
   "source": [
    "def calculate_file_checksum(file_path: str) -> str:\n",
    "    \"\"\"Calculate MD5 checksum of file.\"\"\"\n",
    "    md5_hash = hashlib.md5()\n",
    "    \n",
    "    # Read file from DBFS/Volume\n",
    "    with open(file_path.replace('/Volumes/', '/dbfs/Volumes/'), 'rb') as f:\n",
    "        for chunk in iter(lambda: f.read(4096), b\"\"):\n",
    "            md5_hash.update(chunk)\n",
    "    \n",
    "    return md5_hash.hexdigest()\n",
    "\n",
    "def export_table_to_csv(table_name: str, sort_columns: list, schema: str) -> dict:\n",
    "    \"\"\"\n",
    "    Export table to compressed CSV with deterministic sorting.\n",
    "    Returns metadata about the export.\n",
    "    \"\"\"\n",
    "    print(f\"\\nExporting: {table_name}\")\n",
    "    start_time = datetime.now()\n",
    "    \n",
    "    table_full_name = f\"{CATALOG}.{schema}.{table_name}\"\n",
    "    output_file = f\"{DATA_DIR}/{table_name}.csv.gz\"\n",
    "    \n",
    "    # Load and sort data\n",
    "    print(\"  Loading data...\")\n",
    "    df = spark.table(table_full_name)\n",
    "    row_count = df.count()\n",
    "    \n",
    "    if row_count == 0:\n",
    "        print(\"  ⚠️  Table is empty, skipping...\")\n",
    "        return {\n",
    "            \"table\": table_name,\n",
    "            \"status\": \"skipped\",\n",
    "            \"reason\": \"empty\",\n",
    "            \"row_count\": 0\n",
    "        }\n",
    "    \n",
    "    # Sort by specified columns for determinism\n",
    "    print(f\"  Sorting by: {', '.join(sort_columns)}\")\n",
    "    df_sorted = df.orderBy(*[col(c) for c in sort_columns])\n",
    "    \n",
    "    # Convert to Pandas for CSV export\n",
    "    print(\"  Converting to Pandas...\")\n",
    "    pandas_df = df_sorted.toPandas()\n",
    "    \n",
    "    # Write compressed CSV\n",
    "    print(\"  Writing compressed CSV...\")\n",
    "    local_path = output_file.replace('/Volumes/', '/dbfs/Volumes/')\n",
    "    \n",
    "    with gzip.open(local_path, 'wt', encoding='utf-8') as f:\n",
    "        pandas_df.to_csv(f, index=False, header=True)\n",
    "    \n",
    "    # Calculate checksum\n",
    "    print(\"  Calculating checksum...\")\n",
    "    checksum = calculate_file_checksum(output_file)\n",
    "    \n",
    "    # Get file size\n",
    "    file_size_bytes = os.path.getsize(local_path)\n",
    "    file_size_mb = round(file_size_bytes / (1024 * 1024), 2)\n",
    "    \n",
    "    duration = (datetime.now() - start_time).total_seconds()\n",
    "    \n",
    "    print(f\"  ✓ Exported: {row_count:,} rows, {file_size_mb} MB, {duration:.2f}s\")\n",
    "    print(f\"  ✓ Checksum: {checksum}\")\n",
    "    \n",
    "    # Get schema info\n",
    "    schema_info = [\n",
    "        {\"name\": field.name, \"type\": str(field.dataType)}\n",
    "        for field in df.schema.fields\n",
    "    ]\n",
    "    \n",
    "    return {\n",
    "        \"table\": table_name,\n",
    "        \"status\": \"success\",\n",
    "        \"file\": f\"data/{table_name}.csv.gz\",\n",
    "        \"row_count\": row_count,\n",
    "        \"file_size_bytes\": file_size_bytes,\n",
    "        \"file_size_mb\": file_size_mb,\n",
    "        \"checksum\": checksum,\n",
    "        \"schema\": schema_info,\n",
    "        \"sort_columns\": sort_columns,\n",
    "        \"exported_at\": datetime.now().isoformat(),\n",
    "        \"duration_sec\": round(duration, 2)\n",
    "    }\n",
    "\n",
    "print(\"✓ Export functions loaded\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "7d2b5ff8-f9d6-474f-9636-2db3fee4fc38",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Execute Exports"
    }
   },
   "outputs": [],
   "source": [
    "# Execute exports for all tables\n",
    "export_results = []\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(f\"STARTING CSV SNAPSHOT EXPORT: {SNAPSHOT_TIMESTAMP}\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for table_name, sort_columns, schema in EXPORT_CONFIG:\n",
    "    try:\n",
    "        result = export_table_to_csv(table_name, sort_columns, schema)\n",
    "        export_results.append(result)\n",
    "    except Exception as e:\n",
    "        print(f\"\\n❌ ERROR exporting {table_name}: {str(e)}\")\n",
    "        export_results.append({\n",
    "            \"table\": table_name,\n",
    "            \"status\": \"error\",\n",
    "            \"error\": str(e)\n",
    "        })\n",
    "        continue\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"EXPORT COMPLETE\")\n",
    "print(\"=\"*80)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "0c60839c-d7fc-420a-b179-3321b9228f76",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Generate Checksums File"
    }
   },
   "outputs": [],
   "source": [
    "# Generate checksums.json\n",
    "checksums = {\n",
    "    result['table']: result.get('checksum', None)\n",
    "    for result in export_results\n",
    "    if result['status'] == 'success'\n",
    "}\n",
    "\n",
    "checksums_file = f\"{SNAPSHOT_DIR}/checksums.json\"\n",
    "with open(checksums_file.replace('/Volumes/', '/dbfs/Volumes/'), 'w') as f:\n",
    "    json.dump(checksums, f, indent=2)\n",
    "\n",
    "print(f\"✓ Checksums file: {checksums_file}\")\n",
    "print(f\"  Tables: {len(checksums)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "cfdddfcd-7653-4426-adb2-2b3992abb0bc",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Generate Metadata File"
    }
   },
   "outputs": [],
   "source": [
    "# Generate metadata.json with snapshot details\n",
    "metadata = {\n",
    "    \"snapshot_version\": \"1.0\",\n",
    "    \"snapshot_timestamp\": SNAPSHOT_TIMESTAMP,\n",
    "    \"generated_at\": datetime.now().isoformat(),\n",
    "    \"catalog\": CATALOG,\n",
    "    \"databricks_runtime\": spark.conf.get(\"spark.databricks.clusterUsageTags.sparkVersion\"),\n",
    "    \"format_version\": \"csv_gzip_v1\",\n",
    "    \"compatibility\": {\n",
    "        \"min_consumer_version\": \"1.0\",\n",
    "        \"format\": \"csv\",\n",
    "        \"compression\": \"gzip\",\n",
    "        \"encoding\": \"utf-8\"\n",
    "    },\n",
    "    \"tables\": [\n",
    "        {\n",
    "            \"name\": r['table'],\n",
    "            \"file\": r.get('file'),\n",
    "            \"row_count\": r.get('row_count'),\n",
    "            \"file_size_mb\": r.get('file_size_mb'),\n",
    "            \"schema\": r.get('schema'),\n",
    "            \"sort_columns\": r.get('sort_columns')\n",
    "        }\n",
    "        for r in export_results\n",
    "        if r['status'] == 'success'\n",
    "    ],\n",
    "    \"export_stats\": {\n",
    "        \"total_tables\": len(export_results),\n",
    "        \"successful\": sum(1 for r in export_results if r['status'] == 'success'),\n",
    "        \"failed\": sum(1 for r in export_results if r['status'] == 'error'),\n",
    "        \"skipped\": sum(1 for r in export_results if r['status'] == 'skipped'),\n",
    "        \"total_rows\": sum(r.get('row_count', 0) for r in export_results if r['status'] == 'success'),\n",
    "        \"total_size_mb\": round(sum(r.get('file_size_mb', 0) for r in export_results if r['status'] == 'success'), 2)\n",
    "    }\n",
    "}\n",
    "\n",
    "metadata_file = f\"{SNAPSHOT_DIR}/metadata.json\"\n",
    "with open(metadata_file.replace('/Volumes/', '/dbfs/Volumes/'), 'w') as f:\n",
    "    json.dump(metadata, f, indent=2)\n",
    "\n",
    "print(f\"✓ Metadata file: {metadata_file}\")\n",
    "print(f\"  Total rows: {metadata['export_stats']['total_rows']:,}\")\n",
    "print(f\"  Total size: {metadata['export_stats']['total_size_mb']} MB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "66905875-e3d2-4422-a4e1-2f63101e0779",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Generate Snapshot Manifest"
    }
   },
   "outputs": [],
   "source": [
    "# Generate snapshot_manifest.json (for manifest-driven loading)\n",
    "manifest = {\n",
    "    \"manifest_version\": \"1.0\",\n",
    "    \"snapshot_id\": SNAPSHOT_TIMESTAMP,\n",
    "    \"created_at\": datetime.now().isoformat(),\n",
    "    \"load_order\": [\n",
    "        {\n",
    "            \"sequence\": idx + 1,\n",
    "            \"table\": r['table'],\n",
    "            \"file\": r.get('file'),\n",
    "            \"checksum\": r.get('checksum'),\n",
    "            \"row_count\": r.get('row_count'),\n",
    "            \"sort_columns\": r.get('sort_columns')\n",
    "        }\n",
    "        for idx, r in enumerate(export_results)\n",
    "        if r['status'] == 'success'\n",
    "    ],\n",
    "    \"validation\": {\n",
    "        \"checksum_algorithm\": \"md5\",\n",
    "        \"expected_files\": len([r for r in export_results if r['status'] == 'success']),\n",
    "        \"total_expected_rows\": sum(r.get('row_count', 0) for r in export_results if r['status'] == 'success')\n",
    "    }\n",
    "}\n",
    "\n",
    "manifest_file = f\"{SNAPSHOT_DIR}/snapshot_manifest.json\"\n",
    "with open(manifest_file.replace('/Volumes/', '/dbfs/Volumes/'), 'w') as f:\n",
    "    json.dump(manifest, f, indent=2)\n",
    "\n",
    "print(f\"✓ Snapshot manifest: {manifest_file}\")\n",
    "print(f\"  Load order: {len(manifest['load_order'])} tables\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "d8874748-4189-498c-9a34-62790251ced3",
     "showTitle": true,
     "tableResultSettingsMap": {},
     "title": "Export Summary Report"
    }
   },
   "outputs": [],
   "source": [
    "# Generate summary report\n",
    "import pandas as pd\n",
    "\n",
    "report_df = pd.DataFrame(export_results)\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"EXPORT SUMMARY REPORT\")\n",
    "print(\"=\"*80)\n",
    "print(report_df[['table', 'status', 'row_count', 'file_size_mb', 'duration_sec']].to_string(index=False))\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"SNAPSHOT DETAILS\")\n",
    "print(\"=\"*80)\n",
    "print(f\"Snapshot Directory: {SNAPSHOT_DIR}\")\n",
    "print(f\"Snapshot Timestamp: {SNAPSHOT_TIMESTAMP}\")\n",
    "print(f\"Total Tables: {metadata['export_stats']['total_tables']}\")\n",
    "print(f\"Total Rows: {metadata['export_stats']['total_rows']:,}\")\n",
    "print(f\"Total Size: {metadata['export_stats']['total_size_mb']} MB\")\n",
    "print(f\"\\nFiles Generated:\")\n",
    "print(f\"  ✓ {metadata_file}\")\n",
    "print(f\"  ✓ {checksums_file}\")\n",
    "print(f\"  ✓ {manifest_file}\")\n",
    "print(f\"  ✓ {len(export_results)} CSV files in {DATA_DIR}\")\n",
    "\n",
    "# Log to audit table\n",
    "result_spark_df = spark.createDataFrame(report_df)\n",
    "result_spark_df.write.mode(\"append\").saveAsTable(f\"{CATALOG}.{AUDIT_SCHEMA}.publish_export_log\")\n",
    "\n",
    "print(f\"\\n✓ Export results logged to {AUDIT_SCHEMA}.publish_export_log\")"
   ]
  }
 ],
