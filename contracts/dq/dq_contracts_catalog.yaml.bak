# =====================================================
# LMIP Data Quality Contracts Catalog
# =====================================================
# Purpose: Define data quality contracts for all datasets
# Version: 1.0
# Last Updated: 2026-06-07
# =====================================================

version: "1.0"
framework: "LMIP Data Quality Framework"

# =====================================================
# SEVERITY LEVELS
# =====================================================
severity_levels:
  ERROR:
    description: "Critical data quality issue that prevents data from being used"
    impact: "HIGH"
    requires_immediate_action: true
    
  WARNING:
    description: "Data quality issue that may impact analytics or downstream processes"
    impact: "MEDIUM"
    requires_immediate_action: false
    
  INFO:
    description: "Informational data quality metric for monitoring"
    impact: "LOW"
    requires_immediate_action: false

# =====================================================
# RESPONSE ACTIONS
# =====================================================
response_actions:
  QUARANTINE:
    description: "Move records to quarantine table for manual review"
    target_table: "workspace.quarantine.quarantine_jobs"
    automated: true
    
  ALERT:
    description: "Send alert to data quality team"
    notification_channels:
      - email
      - slack
    automated: true
    
  AUTO_FIX:
    description: "Automatically fix the data quality issue"
    requires_approval: false
    automated: true
    
  FLAG_FOR_REVIEW:
    description: "Flag records for manual review"
    target_queue: "workspace.silver.silver_semantic_review_queue"
    automated: true
    
  QUEUE_FOR_SEMANTIC_REVIEW:
    description: "Queue for semantic layer review"
    target_queue: "workspace.silver.silver_semantic_review_queue"
    automated: true
    
  QUEUE_FOR_NORMALIZATION:
    description: "Queue for normalization processing"
    automated: true
    
  QUEUE_FOR_GEOCODING:
    description: "Queue for geocoding processing"
    automated: true
    
  LOG_WARNING:
    description: "Log warning to audit table"
    target_table: "workspace.audit.audit_dq_results"
    automated: true
    
  LOG_INFO:
    description: "Log informational message"
    target_table: "workspace.audit.audit_dq_results"
    automated: true
    
  CREATE_SEMANTIC_MAPPING:
    description: "Trigger semantic mapping creation"
    automated: true

# =====================================================
# BRONZE LAYER CONTRACTS
# =====================================================
bronze_layer:
  schema: "workspace.bronze"
  description: "Raw ingestion layer - immutable source data"
  
  tables:
    bronze_job_snapshot:
      description: "Raw job posting snapshots from external sources"
      critical_columns:
        - snapshot_id
        - source_name
        - source_job_id
        - payload_json
        - ingestion_timestamp
      validation_rules:
        - rule_id: BR_COMPL_001
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: BR_UNIQ_001
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: BR_UNIQ_002
          category: Uniqueness
          severity: WARNING
          action: LOG_WARNING
        - rule_id: BR_FRESH_001
          category: Freshness
          severity: WARNING
          action: ALERT
      sla:
        freshness_hours: 24
        completeness_threshold: 99.5
        
    batch_metadata:
      description: "Metadata for ingestion batches"
      critical_columns:
        - batch_id
        - source_name
        - started_at
      validation_rules:
        - rule_id: BR_COMPL_002
          category: Completeness
          severity: ERROR
          action: QUARANTINE
      sla:
        freshness_hours: 1
        completeness_threshold: 100.0
        
    bronze_api_response_log:
      description: "API response logging for debugging"
      critical_columns:
        - log_id
        - endpoint
        - response_timestamp
      validation_rules: []
      sla:
        freshness_hours: 24
        
    dedupe_tracking:
      description: "Deduplication tracking metadata"
      critical_columns:
        - tracking_id
        - source_key
      validation_rules: []
      
    watermarks:
      description: "Ingestion watermarks for incremental loads"
      critical_columns:
        - watermark_id
        - source_name
        - watermark_value
      validation_rules: []

# =====================================================
# SILVER LAYER CONTRACTS
# =====================================================
silver_layer:
  schema: "workspace.silver"
  description: "Cleansed and conformed layer"
  
  tables:
    silver_jobs_current:
      description: "Current state of all job postings"
      critical_columns:
        - enterprise_job_id
        - source_name
        - source_job_id
        - title_raw
        - posted_at
        - is_active
      validation_rules:
        - rule_id: SV_COMPL_001
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SV_COMPL_002
          category: Completeness
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: SV_UNIQ_001
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SV_UNIQ_002
          category: Uniqueness
          severity: WARNING
          action: LOG_WARNING
        - rule_id: SV_FRESH_001
          category: Freshness
          severity: WARNING
          action: ALERT
        - rule_id: SV_FRESH_002
          category: Freshness
          severity: ERROR
          action: ALERT
        - rule_id: SV_REF_001
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_001
          category: Business Logic
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_002
          category: Business Logic
          severity: ERROR
          action: AUTO_FIX
        - rule_id: BIZ_003
          category: Business Logic
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_004
          category: Business Logic
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_006
          category: Business Logic
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: BIZ_007
          category: Business Logic
          severity: WARNING
          action: LOG_WARNING
        - rule_id: SECT_001
          category: Sector Classification
          severity: WARNING
          action: QUEUE_FOR_SEMANTIC_REVIEW
        - rule_id: SECT_002
          category: Sector Classification
          severity: WARNING
          action: QUEUE_FOR_SEMANTIC_REVIEW
        - rule_id: SECT_003
          category: Sector Classification
          severity: ERROR
          action: CREATE_SEMANTIC_MAPPING
        - rule_id: SECT_005
          category: Sector Classification
          severity: WARNING
          action: LOG_WARNING
        - rule_id: LOC_001
          category: Location Normalization
          severity: WARNING
          action: QUEUE_FOR_NORMALIZATION
        - rule_id: LOC_007
          category: Location Normalization
          severity: WARNING
          action: LOG_WARNING
      sla:
        freshness_hours: 24
        completeness_threshold: 98.0
        uniqueness_threshold: 100.0
        
    silver_job_changes:
      description: "Change data capture for job postings"
      critical_columns:
        - change_id
        - enterprise_job_id
        - change_type
      validation_rules: []
      
    silver_job_identity_map:
      description: "Job identity resolution mapping"
      critical_columns:
        - mapping_id
      validation_rules:
        - rule_id: SV_UNIQ_003
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
          
    silver_jobs_staging:
      description: "Staging area for job processing"
      critical_columns:
        - staging_id
      validation_rules: []
      
    silver_semantic_review_queue:
      description: "Queue for semantic review items"
      critical_columns:
        - review_id
        - enterprise_job_id
      validation_rules: []
      
    silver_skill_mapping:
      description: "Skill extraction and mapping"
      critical_columns:
        - enterprise_job_id
        - skill_name_raw
      validation_rules:
        - rule_id: SV_COMPL_003
          category: Completeness
          severity: ERROR
          action: QUARANTINE

# =====================================================
# SEMANTIC LAYER CONTRACTS
# =====================================================
semantic_layer:
  schema: "workspace.semantic"
  description: "Semantic entity resolution and mapping"
  
  tables:
    sem_company_canonical:
      description: "Canonical company master"
      critical_columns:
        - canonical_company_id
        - canonical_company_name
      validation_rules:
        - rule_id: SM_COMPL_002
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SM_UNIQ_001
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
          
    sem_company_map:
      description: "Company name to canonical mapping"
      critical_columns:
        - enterprise_job_id
      validation_rules:
        - rule_id: SM_REF_002
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
          
    sem_job_role_map:
      description: "Job title to role mapping"
      critical_columns:
        - enterprise_job_id
      validation_rules: []
      
    sem_job_skill_evidence:
      description: "Skill evidence extraction"
      critical_columns:
        - evidence_id
      validation_rules: []
      
    sem_sector_map:
      description: "Job to sector mapping"
      critical_columns:
        - sector_map_id
        - enterprise_job_id
        - canonical_sector_code
        - canonical_sector_name
      validation_rules:
        - rule_id: SM_COMPL_001
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SM_UNIQ_003
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SM_FRESH_001
          category: Freshness
          severity: WARNING
          action: LOG_WARNING
        - rule_id: SM_REF_001
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_005
          category: Business Logic
          severity: ERROR
          action: QUARANTINE
        - rule_id: SECT_004
          category: Sector Classification
          severity: ERROR
          action: QUARANTINE
        - rule_id: SECT_006
          category: Sector Classification
          severity: WARNING
          action: LOG_WARNING
        - rule_id: SECT_007
          category: Sector Classification
          severity: WARNING
          action: LOG_WARNING
      sla:
        freshness_hours: 48
        completeness_threshold: 95.0
        
    sem_skill_catalog:
      description: "Canonical skill catalog"
      critical_columns:
        - canonical_skill_id
        - canonical_skill_name
      validation_rules:
        - rule_id: SM_COMPL_003
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: SM_UNIQ_002
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
          
    sem_skill_graph_edges:
      description: "Skill relationship graph"
      critical_columns:
        - edge_id
      validation_rules: []

# =====================================================
# WAREHOUSE LAYER CONTRACTS
# =====================================================
warehouse_layer:
  schema: "workspace.warehouse"
  description: "Dimensional model for analytics"
  
  dimensions:
    dim_company:
      description: "Company dimension"
      type: "SCD Type 1"
      critical_columns:
        - company_sk
        - company_name
      validation_rules:
        - rule_id: WH_COMPL_001
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_UNIQ_001
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
      sla:
        completeness_threshold: 100.0
        uniqueness_threshold: 100.0
        
    dim_location:
      description: "Location dimension"
      type: "SCD Type 1"
      critical_columns:
        - location_sk
        - location_name
        - active_flag
      validation_rules:
        - rule_id: WH_COMPL_002
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_UNIQ_002
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: LOC_002
          category: Location Normalization
          severity: ERROR
          action: QUARANTINE
        - rule_id: LOC_003
          category: Location Normalization
          severity: ERROR
          action: QUARANTINE
        - rule_id: LOC_004
          category: Location Normalization
          severity: ERROR
          action: QUARANTINE
        - rule_id: LOC_005
          category: Location Normalization
          severity: WARNING
          action: LOG_WARNING
        - rule_id: LOC_006
          category: Location Normalization
          severity: WARNING
          action: QUEUE_FOR_GEOCODING
        - rule_id: LOC_008
          category: Location Normalization
          severity: ERROR
          action: QUARANTINE
        - rule_id: LOC_009
          category: Location Normalization
          severity: WARNING
          action: LOG_WARNING
        - rule_id: LOC_011
          category: Location Normalization
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: LOC_012
          category: Location Normalization
          severity: WARNING
          action: LOG_WARNING
      sla:
        completeness_threshold: 100.0
        geocoding_coverage: 90.0
        
    dim_sector:
      description: "Industry sector dimension"
      type: "SCD Type 1"
      critical_columns:
        - sector_sk
        - sector_name
        - sector_family
        - active_flag
      validation_rules:
        - rule_id: WH_COMPL_003
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_UNIQ_003
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_009
          category: Business Logic
          severity: WARNING
          action: LOG_WARNING
        - rule_id: SECT_008
          category: Sector Classification
          severity: WARNING
          action: LOG_WARNING
          
    dim_skill:
      description: "Skill dimension"
      type: "SCD Type 1"
      critical_columns:
        - skill_sk
      validation_rules:
        - rule_id: WH_UNIQ_004
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
          
    dim_role:
      description: "Job role dimension"
      type: "SCD Type 1"
      critical_columns:
        - role_sk
      validation_rules: []
      
    dim_job:
      description: "Job dimension"
      type: "SCD Type 2"
      critical_columns:
        - job_sk
      validation_rules: []
      
    dim_source:
      description: "Source system dimension"
      type: "SCD Type 1"
      critical_columns:
        - source_sk
      validation_rules: []
      
    dim_company_alias:
      description: "Company name aliases"
      critical_columns:
        - alias_id
      validation_rules: []
  
  facts:
    fact_job_postings:
      description: "Job posting fact table"
      grain: "One row per job posting per day"
      critical_columns:
        - job_sk
        - company_sk
        - location_sk
        - sector_sk
        - source_sk
      validation_rules:
        - rule_id: WH_COMPL_004
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_FRESH_001
          category: Freshness
          severity: WARNING
          action: ALERT
        - rule_id: WH_REF_001
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_REF_002
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_REF_003
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_REF_004
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_011
          category: Salary Validation
          severity: INFO
          action: LOG_INFO
      sla:
        freshness_hours: 24
        referential_integrity: 100.0
        
    fact_salary:
      description: "Salary observation fact table"
      grain: "One row per salary observation"
      critical_columns:
        - fact_salary_sk
        - job_sk
        - observation_date_sk
        - salary_observation_type
      validation_rules:
        - rule_id: WH_COMPL_005
          category: Completeness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_UNIQ_005
          category: Uniqueness
          severity: ERROR
          action: QUARANTINE
        - rule_id: WH_REF_005
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE
        - rule_id: BIZ_008
          category: Business Logic
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_001
          category: Salary Validation
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_002
          category: Salary Validation
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_003
          category: Salary Validation
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_004
          category: Salary Validation
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_005
          category: Salary Validation
          severity: ERROR
          action: QUARANTINE
        - rule_id: SAL_006
          category: Salary Validation
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: SAL_007
          category: Salary Validation
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: SAL_008
          category: Salary Validation
          severity: WARNING
          action: FLAG_FOR_REVIEW
        - rule_id: SAL_009
          category: Salary Validation
          severity: WARNING
          action: LOG_WARNING
      sla:
        completeness_threshold: 95.0
        valid_range_compliance: 98.0
        
    fact_job_lifecycle:
      description: "Job lifecycle events fact table"
      grain: "One row per lifecycle event"
      critical_columns:
        - lifecycle_sk
      validation_rules: []
      
    fact_pipeline_runs:
      description: "Pipeline execution metrics"
      grain: "One row per pipeline run"
      critical_columns:
        - run_id
      validation_rules: []
  
  bridges:
    bridge_job_skill:
      description: "Many-to-many job to skill bridge"
      critical_columns:
        - job_sk
        - skill_sk
      validation_rules:
        - rule_id: WH_REF_006
          category: Referential Integrity
          severity: ERROR
          action: QUARANTINE

