# =====================================================
# QUARANTINE LAYER CONTRACTS
# =====================================================
quarantine_layer:
  schema: "workspace.quarantine"
  description: "Failed validation records"
  
  tables:
    quarantine_jobs:
      description: "Quarantined job records"
      critical_columns:
        - quarantine_id
        - source_name
        - failure_stage
        - failed_rule_name
        - severity
      validation_rules:
        - rule_id: BIZ_010
          category: Business Logic
          severity: ERROR
          action: ALERT
        - rule_id: BIZ_011
          category: Business Logic
          severity: ERROR
          action: ALERT
        - rule_id: QUAR_REF_001
          category: Referential Integrity
          severity: WARNING
          action: LOG_WARNING

# =====================================================
# AUDIT LAYER CONTRACTS
# =====================================================
audit_layer:
  schema: "workspace.audit"
  description: "Audit and monitoring tables"
  
  tables:
    audit_dq_results:
      description: "Data quality validation results"
      critical_columns:
        - audit_dq_sk
        - run_id
        - rule_name
        - target_table
        - severity
      validation_rules:
        - rule_id: AUDIT_FRESH_001
          category: Freshness
          severity: ERROR
          action: ALERT
      sla:
        freshness_hours: 24
        
    audit_pipeline_runs:
      description: "Pipeline execution audit"
      critical_columns:
        - run_id
      validation_rules: []
      
    audit_access_events:
      description: "Data access audit trail"
      critical_columns:
        - event_id
      validation_rules: []

# =====================================================
# END OF DQ CONTRACTS CATALOG
# =====================================================
